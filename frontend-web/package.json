{
  "name": "nexora-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Nexora AI Web Frontend — Vue3 + TypeScript + Vite",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts",
    "format": "prettier --write \"src/**/*.{vue,ts,css,json}\"",
    "test:e2e": "playwright test",
    "generate-api": "openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g typescript-axios -o src/api/generated"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.2.6",
    "element-plus": "^2.9.1",
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "echarts": "^5.5.1",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^10.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0",
    "@types/node": "^22.10.2",
    "sass": "^1.83.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "@playwright/test": "^1.49.1",
    "@openapitools/openapi-generator-cli": "^2.15.3"
  }
}
